<%- include('partials/header') %>

    <main>

        <h1>
            <%= project.title %>
        </h1>

        <p>
            <strong>Description:</strong>
            <%= project.description %>
        </p>

        <p>
            <strong>Date:</strong>
            <%= new Date(project.date).toLocaleDateString() %>
        </p>

        <p>
            <strong>Location:</strong>
            <%= project.location %>
        </p>

        <p>
            <strong>Organization:</strong>

            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <p>
            <strong>Categories:</strong>

            <% categories.forEach(category=> { %>

                <a href="/category/<%= category.category_id %>">
                    <%= category.name %>
                </a>

                <% }) %>

        </p>

        <div class="link-actions">
            <% if (user && user.role_name==='admin' ) { %>
                <a href="/edit-project/<%= project.project_id %>">
                    Edit Project
                </a>

                <a href="/assign-categories/<%= project.project_id %>">
                    Edit Categories
                </a>
                <% } %>
        </div>

        <% if (user) { %>

            <div class="link-actions">

                <% if (!isVolunteer) { %>

                    <form action="/project/<%= project.project_id %>/volunteer" method="POST">

                        <button type="submit">
                            Volunteer for this Project
                        </button>

                    </form>

                    <% } else { %>

                        <div class="volunteer-actions">

                            <p>
                                <strong>You are volunteering for this project.</strong>
                            </p>

                            <form action="/project/<%= project.project_id %>/remove-volunteer" method="POST">

                                <button type="submit">
                                    Remove Volunteer Status
                                </button>

                            </form>

                        </div>

                        <% } %>
            </div>

            <% } %>

    </main>

    <%- include('partials/footer') %>