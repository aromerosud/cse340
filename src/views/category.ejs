<%- include('partials/header') %>

    <main>

        <h1>
            <%= category.name %>
        </h1>

        <h2>Projects</h2>

        <ul>

            <% projects.forEach(project=> { %>

                <li>

                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>

                </li>

                <% }) %>

        </ul>

        <div class="link-actions">
            <p><a href="/edit-category/<%= category.category_id %>">Edit Category</a></p>
        </div>

    </main>

    <%- include('partials/footer') %>